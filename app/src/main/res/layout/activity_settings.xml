<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Theme Mode"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <RadioGroup
        android:id="@+id/rg_theme_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/rb_theme_system"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="System Default"
            android:textSize="18sp"
            android:padding="8dp"/>

        <RadioButton
            android:id="@+id/rb_theme_light"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Light"
            android:textSize="18sp"
            android:padding="8dp"/>

        <RadioButton
            android:id="@+id/rb_theme_dark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dark"
            android:textSize="18sp"
            android:padding="8dp"/>
    </RadioGroup>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Output Format Strategy"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <RadioGroup
        android:id="@+id/rg_format_strategy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rb_text_format"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Text Format"
            android:textSize="18sp"
            android:padding="8dp"/>

        <RadioButton
            android:id="@+id/rb_image_format"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Image Format (Scryfall)"
            android:textSize="18sp"
            android:padding="8dp"/>
    </RadioGroup>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btn_save_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save"
        android:background="@color/colorAccent"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:padding="12dp"
        android:layout_marginTop="16dp"/>

</LinearLayout>
